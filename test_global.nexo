using nexocore.io
using nexocore.system

do TestDynamicCollections() {
    print_border()
    write "Testing N# Phase 6: Dynamic Heap Collections"
    
    <3 Dynamic Array allocation
    var monsters = ["Orco", "Goblin", "Troll"]
    
    <3 Index Access and Mutability
    monsters[1] = "Hobgoblin"
    
    write "Active enemies in sector:"
    
    <3 Foreach Iteration looping directly through boxed references
    foreach m in monsters: {
        write m
    }
    
    print_border()
}

TestDynamicCollections()
