using nexocore.math
using nexocore.system

do CalculateAbsolute() {
    <3 System allocates local mutable reference `res` upon execution
    res = abs(0 - 55)
    
    write "Global absolute payload evaluation returned:"
    write res
    
    <3 Asserts equality constraint, expecting positive integer 1 returned upon success
    success_flag = assert(res == 55, "Math assertion failed fatally!")
    
    <3 Conditional branch triggering purely if logic succeeds without crashing
    if success_flag == 1: {
        write "All CoreLibs Engine validations passed beautifully!"
    }
}

<3 Bootstraps the global test execution frame sequentially
CalculateAbsolute()
